  "publicApiSurface": [
    "GET /database/bodega.php - List all warehouses",
    "POST /database/bodega.php - Create new warehouse",
    "PUT /database/bodega.php - Update warehouse",
    "DELETE /database/bodega.php - Delete warehouse",
    "GET /database/categorias.php - List all categories",
    "POST /database/categorias.php - Create new category",
    "PUT /database/categorias.php - Update category",
    "DELETE /database/categorias.php - Delete category",
    "GET /database/subcategorias.php - List subcategories",
    "POST /database/subcategorias.php - Create subcategory",
    "PUT /database/subcategorias.php - Update subcategory",
    "DELETE /database/subcategorias.php - Delete subcategory",
    "GET /database/proveedores.php - List suppliers",
    "POST /database/proveedores.php - Create supplier",
    "PUT /database/proveedores.php - Update supplier",
    "DELETE /database/proveedores.php - Delete supplier",
    "GET /database/parametros.php - List inventory parameters",
    "POST /database/parametros.php - Create parameter",
    "PUT /database/parametros.php - Update parameter",
    "DELETE /database/parametros.php - Delete parameter",
    "POST /database/registro.php - Register new user"
