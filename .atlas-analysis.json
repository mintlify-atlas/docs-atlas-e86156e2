  "keyFeatures": [
    "Warehouse and storage location management",
    "Product categorization with categories and subcategories",
    "Inventory tracking with min/max stock levels and expiration dates",
    "Supplier management and tracking",
    "Customizable inventory parameters and concepts",
    "User authentication and registration",
    "Real-time inventory reporting",
    "Product movement tracking (entries, exits, returns)",
    "Color-coded category system",
